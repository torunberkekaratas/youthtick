{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/tr", "destination": "/tr/index.html", "permanent": false },
    { "source": "/de", "destination": "/de/index.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/tr/:path*", "destination": "/:path*" },
    { "source": "/de/:path*", "destination": "/:path*" },
    { "source": "/404",       "destination": "/404.html" }
  ]
}
