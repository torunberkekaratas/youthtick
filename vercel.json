{
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/yalova-erasmus",    "destination": "/yalova-erasmus.html" },
    { "source": "/yalova-erasmus/",   "destination": "/yalova-erasmus.html" },
    { "source": "/tr",                "destination": "/" },
    { "source": "/tr/",               "destination": "/" },
    { "source": "/de",                "destination": "/" },
    { "source": "/de/",               "destination": "/" },
    { "source": "/tr/yalova-erasmus", "destination": "/yalova-erasmus.html" },
    { "source": "/tr/yalova-erasmus/","destination": "/yalova-erasmus.html" },
    { "source": "/de/yalova-erasmus", "destination": "/yalova-erasmus.html" },
    { "source": "/de/yalova-erasmus/","destination": "/yalova-erasmus.html" },
    { "source": "/tr/:path*",         "destination": "/:path*" },
    { "source": "/de/:path*",         "destination": "/:path*" },
    { "source": "/404",               "destination": "/404.html" }
  ]
}
