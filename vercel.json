{
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.jpg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/yalova-erasmus",    "destination": "/yalova-erasmus.html" },
    { "source": "/yalova-erasmus/",   "destination": "/yalova-erasmus.html" },
    { "source": "/tr",                "destination": "/" },
    { "source": "/tr/",               "destination": "/" },
    { "source": "/de",                "destination": "/" },
    { "source": "/de/",               "destination": "/" },
    { "source": "/tr/yalova-erasmus", "destination": "/yalova-erasmus.html" },
    { "source": "/tr/yalova-erasmus/","destination": "/yalova-erasmus.html" },
    { "source": "/de/yalova-erasmus", "destination": "/yalova-erasmus.html" },
    { "source": "/de/yalova-erasmus/","destination": "/yalova-erasmus.html" },
    { "source": "/404",               "destination": "/404.html" },
    { "source": "/tr/blog/:slug",     "destination": "/tr/blog/:slug" },
    { "source": "/de/blog/:slug",     "destination": "/de/blog/:slug" },
    { "source": "/tr/:path*",         "destination": "/:path*" },
    { "source": "/de/:path*",         "destination": "/:path*" }
  ]
}
